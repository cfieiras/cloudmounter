<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>CloudMounter</string>
    <key>CFBundleIdentifier</key>
    <string>com.cloudmounter.app</string>
    <key>CFBundleName</key>
    <string>CloudMounter</string>
    <key>CFBundleDisplayName</key>
    <string>CloudMounter</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleIconFile</key>
    <string>CloudMounter</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>LSUIElement</key>
    <false/>
    <key>NSHumanReadableCopyright</key>
    <string>© 2026 CloudMounter. All rights reserved.</string>
    <!-- App metadata -->
    <key>NSApplicationName</key>
    <string>CloudMounter</string>
    <key>NSApplicationVersion</key>
    <string>1.0.0</string>
    <!-- Disable sandbox to allow rclone execution and FUSE mounts -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Hardened runtime: allow unsigned executables (rclone) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- AppleScript (for opening Terminal with rclone config) -->
    <key>NSAppleScriptEnabled</key>
    <true/>
    <!-- Notifications -->
    <key>NSUserNotificationAlertStyle</key>
    <string>alert</string>
    <!-- File type associations (optional, for future) -->
    <key>UTExportedTypeDeclarations</key>
    <array/>
</dict>
</plist>
